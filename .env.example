# Copy to api/.env for local development. Never commit a filled-in .env.

LGAPP_ENV=local
LGAPP_LOG_LEVEL=INFO

# Local Postgres from docker-compose.yml at the repo root.
LGAPP_DATABASE_URL=postgresql+asyncpg://lgapp:lgapp@localhost:5432/lgapp

# Supabase project ref, e.g. abcdefghijklmnop — the API derives the JWKS URL and the
# expected JWT issuer from this. Required once auth is wired up.
LGAPP_SUPABASE_PROJECT_REF=

# Comma-separated. The Vite dev server default is below.
LGAPP_CORS_ORIGINS=["http://localhost:5173"]
