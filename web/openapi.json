{
  "openapi": "3.1.0",
  "info": {
    "title": "Learn German API",
    "version": "0.1.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Liveness probe",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Healthz Healthz Get"
                }
              }
            }
          }
        }
      }
    },
    "/readyz": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Readiness probe \u2014 checks the database round-trips",
        "operationId": "readyz_readyz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Readyz Readyz Get"
                }
              }
            }
          }
        }
      }
    },
    "/v1/decks": {
      "get": {
        "tags": [
          "decks"
        ],
        "summary": "List decks with the learner's progress",
        "operationId": "list_decks_v1_decks_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/DeckOut"
                  },
                  "type": "array",
                  "title": "Response List Decks V1 Decks Get"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/v1/decks/{deck_id}/subscribe": {
      "post": {
        "tags": [
          "decks"
        ],
        "summary": "Subscribe to a deck",
        "description": "Idempotent: re-subscribing picks up newly imported cards and leaves progress alone.",
        "operationId": "subscribe_to_deck_v1_decks__deck_id__subscribe_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "deck_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Deck Id"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscribeOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/reviews/queue": {
      "get": {
        "tags": [
          "reviews"
        ],
        "summary": "Cards to review now",
        "operationId": "get_queue_v1_reviews_queue_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "deck_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Deck Id"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 200,
              "minimum": 1,
              "default": 50,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/reviews": {
      "post": {
        "tags": [
          "reviews"
        ],
        "summary": "Submit a batch of reviews",
        "description": "Record reviews and return the authoritative card states.\n\nAccepts a batch because an offline client drains its outbox at once, and is\nidempotent on review id so a retry after a timeout cannot double-apply.",
        "operationId": "post_reviews_v1_reviews_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReviewBatchIn"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReviewBatchOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/v1/stats": {
      "get": {
        "tags": [
          "stats"
        ],
        "summary": "Progress statistics",
        "operationId": "get_stats_v1_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsOut"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CardOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "german": {
            "type": "string",
            "title": "German"
          },
          "english": {
            "type": "string",
            "title": "English"
          },
          "part_of_speech": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Part Of Speech"
          },
          "article": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Article"
          },
          "plural": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Plural"
          },
          "example_de": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Example De"
          },
          "example_en": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Example En"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tags"
          }
        },
        "type": "object",
        "required": [
          "id",
          "german",
          "english"
        ],
        "title": "CardOut"
      },
      "CardState": {
        "type": "string",
        "enum": [
          "learning",
          "review",
          "relearning"
        ],
        "title": "CardState",
        "description": "Mirrors FSRS's own card states; mapped in services/scheduler.py."
      },
      "CardStateOut": {
        "properties": {
          "card_id": {
            "type": "string",
            "format": "uuid",
            "title": "Card Id"
          },
          "state": {
            "$ref": "#/components/schemas/CardState"
          },
          "due": {
            "type": "string",
            "format": "date-time",
            "title": "Due"
          },
          "stability": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Stability"
          },
          "difficulty": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Difficulty"
          },
          "reps": {
            "type": "integer",
            "title": "Reps"
          },
          "lapses": {
            "type": "integer",
            "title": "Lapses"
          },
          "last_review": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Review"
          }
        },
        "type": "object",
        "required": [
          "card_id",
          "state",
          "due",
          "reps",
          "lapses"
        ],
        "title": "CardStateOut",
        "description": "Authoritative post-sync state. The client overwrites its local copy with this."
      },
      "DayCount": {
        "properties": {
          "day": {
            "type": "string",
            "title": "Day"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          }
        },
        "type": "object",
        "required": [
          "day",
          "count"
        ],
        "title": "DayCount"
      },
      "DeckOut": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "slug": {
            "type": "string",
            "title": "Slug"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "cefr_level": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Cefr Level"
          },
          "card_count": {
            "type": "integer",
            "title": "Card Count"
          },
          "subscribed": {
            "type": "boolean",
            "title": "Subscribed"
          },
          "due_count": {
            "type": "integer",
            "title": "Due Count",
            "default": 0
          }
        },
        "type": "object",
        "required": [
          "id",
          "slug",
          "name",
          "card_count",
          "subscribed"
        ],
        "title": "DeckOut"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "QueueCardOut": {
        "properties": {
          "card": {
            "$ref": "#/components/schemas/CardOut"
          },
          "state": {
            "$ref": "#/components/schemas/CardState"
          },
          "due": {
            "type": "string",
            "format": "date-time",
            "title": "Due"
          },
          "reps": {
            "type": "integer",
            "title": "Reps"
          },
          "is_new": {
            "type": "boolean",
            "title": "Is New"
          }
        },
        "type": "object",
        "required": [
          "card",
          "state",
          "due",
          "reps",
          "is_new"
        ],
        "title": "QueueCardOut"
      },
      "QueueOut": {
        "properties": {
          "cards": {
            "items": {
              "$ref": "#/components/schemas/QueueCardOut"
            },
            "type": "array",
            "title": "Cards"
          },
          "due_total": {
            "type": "integer",
            "title": "Due Total"
          },
          "new_remaining_today": {
            "type": "integer",
            "title": "New Remaining Today"
          }
        },
        "type": "object",
        "required": [
          "cards",
          "due_total",
          "new_remaining_today"
        ],
        "title": "QueueOut"
      },
      "Rating": {
        "type": "integer",
        "enum": [
          1,
          2,
          3,
          4
        ],
        "title": "Rating",
        "description": "FSRS grades. Stored as a smallint so ordering comparisons stay cheap."
      },
      "ReviewBatchIn": {
        "properties": {
          "reviews": {
            "items": {
              "$ref": "#/components/schemas/ReviewIn"
            },
            "type": "array",
            "maxItems": 500,
            "minItems": 1,
            "title": "Reviews"
          }
        },
        "type": "object",
        "required": [
          "reviews"
        ],
        "title": "ReviewBatchIn"
      },
      "ReviewBatchOut": {
        "properties": {
          "cards": {
            "items": {
              "$ref": "#/components/schemas/CardStateOut"
            },
            "type": "array",
            "title": "Cards"
          }
        },
        "type": "object",
        "required": [
          "cards"
        ],
        "title": "ReviewBatchOut"
      },
      "ReviewIn": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "card_id": {
            "type": "string",
            "format": "uuid",
            "title": "Card Id"
          },
          "rating": {
            "$ref": "#/components/schemas/Rating"
          },
          "reviewed_at": {
            "type": "string",
            "format": "date-time",
            "title": "Reviewed At"
          },
          "duration_ms": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Ms"
          }
        },
        "type": "object",
        "required": [
          "id",
          "card_id",
          "rating",
          "reviewed_at"
        ],
        "title": "ReviewIn",
        "description": "One review from the client.\n\n`id` is generated client-side at review time so that a retry after a network failure\ncarries the same id and is absorbed rather than double-counted. `reviewed_at` is when\nthe learner actually answered, which for an offline review is well before we see it."
      },
      "StatsOut": {
        "properties": {
          "reviews_total": {
            "type": "integer",
            "title": "Reviews Total"
          },
          "reviews_today": {
            "type": "integer",
            "title": "Reviews Today"
          },
          "retention_rate": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Retention Rate",
            "description": "Share of mature reviews graded better than Again."
          },
          "streak_days": {
            "type": "integer",
            "title": "Streak Days"
          },
          "cards_by_state": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Cards By State"
          },
          "due_today": {
            "type": "integer",
            "title": "Due Today"
          },
          "reviews_per_day": {
            "items": {
              "$ref": "#/components/schemas/DayCount"
            },
            "type": "array",
            "title": "Reviews Per Day"
          }
        },
        "type": "object",
        "required": [
          "reviews_total",
          "reviews_today",
          "streak_days",
          "cards_by_state",
          "due_today",
          "reviews_per_day"
        ],
        "title": "StatsOut"
      },
      "SubscribeOut": {
        "properties": {
          "deck_id": {
            "type": "string",
            "format": "uuid",
            "title": "Deck Id"
          },
          "cards_added": {
            "type": "integer",
            "title": "Cards Added"
          }
        },
        "type": "object",
        "required": [
          "deck_id",
          "cards_added"
        ],
        "title": "SubscribeOut"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
