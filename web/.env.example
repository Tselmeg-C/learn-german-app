# Copy to web/.env.local. Vite only exposes VITE_-prefixed variables to the client —
# never put a service-role key or anything secret here; this file ships to the browser.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Leave blank in development: vite.config.ts proxies /v1 to the local API, keeping the
# client same-origin. Set to the deployed API origin in production.
VITE_API_URL=
